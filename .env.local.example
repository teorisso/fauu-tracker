# Supabase — copiá estos valores desde tu proyecto en supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública de la app (en producción: tu dominio de Vercel)
# Usada en los emails de notificación de vencimientos
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (clave pública VAPID — la privada va solo en secrets de Supabase para la Edge Function)
# Generar par: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
