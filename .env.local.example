# Supabase — copiá estos valores desde tu proyecto en supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública de la app (en producción: tu dominio de Vercel)
# Usada en los emails de notificación de vencimientos
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push — misma Public Key que en Supabase (VAPID_PUBLIC_KEY en secrets)
# Generar par: npx web-push generate-vapid-keys
# Preferí esta variable en Vercel (se lee en runtime en /api/vapid-public):
VAPID_PUBLIC_KEY=
# Alternativa (se inyecta al build del cliente):
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
